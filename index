  const rows = [
    {lbl:'Height (m)', fn: s=>`<input type="number" value="${escH(SEC_HEIGHTS[s])}" placeholder="0" oninput="SEC_HEIGHTS['${s}']=this.value" style="text-align:center"/>`},
    {lbl:'Azimuth',    fn: s=>`<input type="number" value="${escH(TECH_DATA[tech]?.[s]?.azimuth)}" placeholder="0" oninput="TECH_DATA['${tech}']['${s}'].azimuth=this.value" style="text-align:center"/>`},
    {lbl:'Antenna',    fn: s=>`<select onchange="TECH_DATA['${tech}']['${s}'].antennaType=this.value">${ANT_TYPES.map(a=>`<option ${TECH_DATA[tech]?.[s]?.antennaType===a?'selected':''}>${escH(a)}</option>`).join('')}</select>`},
    {lbl:'M.Tilt',     fn: s=>`<select onchange="TECH_DATA['${tech}']['${s}'].mTilt=this.value">${TILT_VALS.map(v=>`<option ${TECH_DATA[tech]?.[s]?.mTilt===v?'selected':''}>${escH(v)}</option>`).join('')}</select>`},
    {lbl:'E.Tilt',     fn: s=>`<select onchange="TECH_DATA['${tech}']['${s}'].eTilt=this.value">${TILT_VALS.map(v=>`<option ${TECH_DATA[tech]?.[s]?.eTilt===v?'selected':''}>${escH(v)}</option>`).join('')}</select>`},
  ];
  return `<div class="tech-panel">
<div class="tech-header ${cc}"><h4>📡 ${tech} Sector Details</h4>
${cf?`<button class="btn btn-sm" style="background:rgba(255,255,255,.2);color:#fff;border:1px solid rgba(255,255,255,.3)" onclick="copyTech('${cf}','${tech}')">Copy from ${cf}</button>`:''}</div>
