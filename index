        <div id="debug-box" style="margin-top:12px;padding:12px;background:#f1f5f9;border-radius:8px;font-size:12px;font-family:monospace;color:#334155;white-space:pre-wrap;word-break:break-all;display:none"></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:16px;font-size:12px;color:var(--muted)">Same credentials as the OnRoute mobile app.</p>
