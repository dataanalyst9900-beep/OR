async function sbFetch(path, opts={}) {
  const tok = AUTH?.accessToken || SB_ANON;
  const headers = { 'apikey': SB_ANON, 'Authorization': 'Bearer '+tok, 'Content-Type': 'application/json', ...(opts.headers||{}) };
  return fetch(SB_URL + path, { ...opts, headers });
}

// ═══════════════════════════════════════════════════════════════════════════
// SSL SITES
// ═══════════════════════════════════════════════════════════════════════════
async function loadSites() {
  if (SSL_CACHE.length > 0) { SSL_LOADED = true; renderSiteCount(); return; }
  const all = []; let off = 0;
  while (true) {
    const r = await fetch(`${SSL_URL}/rest/v1/SSL?select=Site,Grid,SiteTechnology,Latitude,Longitude&order=Site.asc&offset=${off}&limit=1000`, {
      headers: { 'apikey': SSL_ANON, 'Authorization': 'Bearer '+SSL_ANON, 'Prefer': 'count=none' }
    });
    if (!r.ok) break;
    const arr = await r.json();
    arr.forEach(row => {
      const id = row.Site || row.site || '';
      if (id && id !== 'null') all.push({ siteId:id, gridId:row.Grid||'', siteName:id, siteTech:row.SiteTechnology||'', lat:parseFloat(row.Latitude||0), lng:parseFloat(row.Longitude||0) });
    });
    if (arr.length < 1000) break;
    off += 1000;
  }
  SSL_CACHE = all; SSL_LOADED = true;
  renderSiteCount();
}

function renderSiteCount() {
  const el = document.getElementById('site-count');
  if (el) el.textContent = SSL_LOADED ? SSL_CACHE.length.toLocaleString()+' sites loaded' : '⏳ Loading…';
}

function searchSites(q) {
  if (!q || q.length < 2) return [];
  const ql = q.toLowerCase();
  return SSL_CACHE.filter(s => s.siteId.toLowerCase().includes(ql)).slice(0, 40);
}

