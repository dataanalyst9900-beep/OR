</div>
${a.remarks?`<div style="margin-top:10px"><div style="font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.4px">Remarks</div><div style="margin-top:4px;font-size:13px">${escH(a.remarks)}</div></div>`:''}
${a.approver_remarks?`<div class="${a.status==='rejected'?'reject-box':'approve-box'}" style="margin-top:10px"><b>${a.status==='rejected'?'Rejection Reason':'Approver Remarks'}:</b> ${escH(a.approver_remarks)}</div>`:''}
</div>
${secs.map(sec => {
  const ph = sec.photo_url;
  return `<hr class="sep"/>
<div><strong style="font-size:13px">Sector ${escH(sec.sector)}${sec.antenna_height?' · H: '+escH(sec.antenna_height)+'m':''}</strong>
<div style="overflow-x:auto;margin-top:8px">
<table style="width:100%;border-collapse:collapse;min-width:400px;font-size:12px">
<thead><tr><th style="padding:6px 10px;background:var(--bg);border-bottom:1px solid var(--border);text-align:left;color:var(--muted);font-size:11px;text-transform:uppercase">Field</th>
${TECHS.map(t=>`<th style="padding:6px 8px;background:var(--bg);border-bottom:1px solid var(--border);text-align:center;font-size:11px;color:var(--muted);text-transform:uppercase">${t}</th>`).join('')}</tr></thead>
<tbody>
${[['Antenna','antenna_type'],['Azimuth','azimuth'],['M.Tilt','m_tilt'],['E.Tilt','e_tilt']].map(([lbl,key])=>`<tr>
<td style="padding:5px 10px;color:var(--muted);border-bottom:1px solid var(--border);font-weight:600">${lbl}</td>
${TECHS.map(t=>{const td=sec['tech_'+t.toLowerCase()];const v=td?(td[key]||'—'):'—';return`<td style="padding:5px 8px;text-align:center;border-bottom:1px solid var(--border);font-family:var(--mono)">${escH(v)}</td>`;}).join('')}</tr>`).join('')}
</tbody></table></div>
${ph?`<div style="margin-top:10px"><img src="${escH(ph)}" class="photo-thumb" onclick="MODAL_DATA={type:'photo',url:'${escH(ph)}'};renderModal()"/></div>`:''}</div>`;
}).join('')}
${isApr?`<hr class="sep"/><div class="form-group"><label>Approver Remarks (optional)</label><textarea id="appr-remarks" placeholder="Comments visible to auditor…"></textarea></div>`:''}
</div>
<div class="modal-footer">
${isApr
  ? `<button class="btn btn-outline" onclick='openApprEdit(${escJ(a)})'>✏ Edit & Approve</button>
     <button class="btn btn-danger" onclick="openReject('${a.id}')">✕ Reject</button>
     <button class="btn btn-success" onclick="doApprove('${a.id}')">✓ Approve</button>`
  : `<button class="btn btn-outline" onclick="closeModal()">Close</button>`}
</div></div></div>`;
  }
}

function closeModal() { MODAL_DATA = null; renderModal(); }

// ═══════════════════════════════════════════════════════════════════════════
// ACTION HANDLERS
// ═══════════════════════════════════════════════════════════════════════════
function onSearch(q) { SEARCH_Q=q; SEARCH_RES=searchSites(q); SEL_SITE=null; renderPage(); }
function pickSite(s) { SEL_SITE=s; IS_CUSTOM=false; SEARCH_Q=s.siteId; SEARCH_RES=[]; renderPage(); }
function addCustom()  { const id=SEARCH_Q.trim().toUpperCase(); if(!id)return; SEL_SITE={siteId:id,gridId:'',siteName:id,siteTech:''}; IS_CUSTOM=true; SEARCH_RES=[]; renderPage(); }
function onST(v)      { SITE_TYPE=v; if(v==='IBS')TOWER_TYPE=''; renderPage(); }
function copyTech(from,to) { SECTORS.forEach(s=>{TECH_DATA[to][s]={...TECH_DATA[from][s]};}); renderPage(); }
function cancelEdit() { resetForm(); renderPage(); }

function resetForm() {
  SEL_SITE=null; IS_CUSTOM=false; SEARCH_Q=''; SEARCH_RES=[];
  SITE_TYPE='Green Field'; TOWER_TYPE='Tower'; BLDG_H=''; TOWER_H=''; REMARKS='';
  RESUB_ID=null; APPR_EDIT_ID=null; SUBMIT_ST=null; initTD();
}

function restoreSectors(sectors) {
  initTD();
  if (!sectors) return;
  const arr = Array.isArray(sectors) ? sectors : (typeof sectors==='string' ? JSON.parse(sectors) : []);
  arr.forEach(sec => {
    const s = sec.sector; if (!s) return;
    SEC_HEIGHTS[s] = sec.antenna_height||'';
    TECHS.forEach(t => { const td=sec['tech_'+t.toLowerCase()]; if(td&&TECH_DATA[t]) TECH_DATA[t][s]={antennaType:td.antenna_type||'',azimuth:td.azimuth||'',mTilt:td.m_tilt||'',eTilt:td.e_tilt||''}; });
  });
}

function openDetail(a, isApr=false) { MODAL_DATA={type:'detail',audit:a,isApprover:isApr}; renderModal(); }
function openReject(id) { MODAL_DATA={type:'reject',auditId:id}; renderModal(); }

function openResub(a) {
  RESUB_ID=a.id; APPR_EDIT_ID=null;
  SEL_SITE={siteId:a.site_id,gridId:a.grid_id||'',siteName:a.site_id,siteTech:''}; IS_CUSTOM=true; SEARCH_Q=a.site_id;
  SITE_TYPE=a.site_type||'Green Field'; TOWER_TYPE=a.tower_type||'Tower';
  BLDG_H=a.building_height||''; TOWER_H=a.tower_height||''; REMARKS=a.remarks||'';
  restoreSectors(a.sectors); PAGE='new'; renderPage(); window.scrollTo(0,0);
}

function openApprEdit(a) {
  APPR_EDIT_ID=a.id; RESUB_ID=null;
  SEL_SITE={siteId:a.site_id,gridId:a.grid_id||'',siteName:a.site_id,siteTech:''}; IS_CUSTOM=true; SEARCH_Q=a.site_id;
  SITE_TYPE=a.site_type||'Green Field'; TOWER_TYPE=a.tower_type||'Tower';
  BLDG_H=a.building_height||''; TOWER_H=a.tower_height||''; REMARKS=a.remarks||'';
  restoreSectors(a.sectors); MODAL_DATA=null; PAGE='new'; renderPage(); window.scrollTo(0,0);
}

async function qApprove(id) {
  if (!confirm('Approve this audit?')) return;
  const ok = await patchAudit(id, {status:'approved', approved_at:new Date().toISOString()});
  if (ok) { loadPending(); loadHistory(); } else alert('Approval failed.');
}

async function doApprove(id) {
  const remarks = document.getElementById('appr-remarks')?.value||'';
  const ok = await patchAudit(id, {status:'approved', approved_at:new Date().toISOString(), ...(remarks?{approver_remarks:remarks}:{})});
  if (ok) { closeModal(); loadPending(); loadHistory(); } else alert('Approval failed.');
}

async function doReject(id) {
  const reason = document.getElementById('reject-reason')?.value||'';
  if (!reason.trim()) { alert('Please enter a reason.'); return; }
  const ok = await patchAudit(id, {status:'rejected', approver_remarks:reason});
  if (ok) { closeModal(); loadPending(); loadHistory(); } else alert('Rejection failed.');
}

// ═══════════════════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════════════════
// Wire sign out button whenever app is shown
function wireAppButtons() {
  const so = document.getElementById('btn-signout');
  if (so) so.onclick = doSignOut;
}

