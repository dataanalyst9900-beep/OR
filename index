function navTo(p) { PAGE = p; if(p==='history') loadHistory(); if(p==='approvals') loadPending(); renderPage(); }

function escH(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escJ(o) { return JSON.stringify(o).replace(/"/g,'&quot;'); }
function fmtDate(iso) { return iso ? iso.slice(0,10) : '—'; }
function fmtDT(iso)   { return iso ? iso.slice(0,16).replace('T',' ') : '—'; }
function statusBadge(s) {
  if (s==='approved') return '<span class="badge badge-approved">✓ Approved</span>';
  if (s==='rejected') return '<span class="badge badge-rejected">✕ Rejected</span>';
