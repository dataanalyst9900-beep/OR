// AUDIT CRUD
// ═══════════════════════════════════════════════════════════════════════════
function buildSectors() {
  return SECTORS.map(s => {
    const obj = { sector:s, antenna_height:SEC_HEIGHTS[s]||'', photo_url:'' };
    TECHS.forEach(t => { const td = TECH_DATA[t]?.[s]||{}; obj['tech_'+t.toLowerCase()] = { antenna_type:td.antennaType||'', azimuth:td.azimuth||'', m_tilt:td.mTilt||'', e_tilt:td.eTilt||'' }; });
    return obj;
  });
}

async function doSubmit() {
  if (!SEL_SITE) { SUBMIT_ST = {type:'error',msg:'Please select a site first.'}; renderPage(); return; }
  SUBMITTING = true; SUBMIT_ST = null; renderPage();
  const now = new Date().toISOString();
  const sectors = buildSectors();

  if (RESUB_ID) {
    const ok = await patchAudit(RESUB_ID, { site_type:SITE_TYPE, tower_type:SITE_TYPE==='IBS'?'':TOWER_TYPE, building_height:BLDG_H, tower_height:TOWER_H, sectors, remarks:REMARKS, status:'pending_approval', approved_at:null, approver_remarks:null });
    SUBMITTING = false; SUBMIT_ST = ok ? {type:'success',msg:'Resubmitted — pending approval.'} : {type:'error',msg:'Resubmit failed.'};
    if (ok) { resetForm(); loadHistory(); } renderPage(); return;
  }
  if (APPR_EDIT_ID) {
    const ok = await patchAudit(APPR_EDIT_ID, { site_type:SITE_TYPE, tower_type:SITE_TYPE==='IBS'?'':TOWER_TYPE, building_height:BLDG_H, tower_height:TOWER_H, sectors, remarks:REMARKS, status:'approved', approved_at:now });
    SUBMITTING = false; SUBMIT_ST = ok ? {type:'success',msg:'Saved and approved!'} : {type:'error',msg:'Save failed.'};
    if (ok) { resetForm(); loadPending(); loadHistory(); } renderPage(); return;
  }

  const id = crypto.randomUUID();
  const { error } = await _sb.from('site_audits').insert({ id, site_id:SEL_SITE.siteId, site_name:SEL_SITE.siteName, grid_id:SEL_SITE.gridId, site_type:SITE_TYPE, tower_type:SITE_TYPE==='IBS'?'':TOWER_TYPE, building_height:BLDG_H, tower_height:TOWER_H, sectors, remarks:REMARKS, submitted_by:AUTH.uid, submitted_by_name:AUTH.name, company:AUTH.company, submitted_at:now, status:'pending_approval' });
  SUBMITTING = false;
  SUBMIT_ST = !error ? {type:'success',msg:'Audit submitted — pending approval.'} : {type:'error',msg:'Submission failed: '+(error.message||'')};
  if (!error) { resetForm(); loadHistory(); }
  renderPage();
}

async function patchAudit(id, updates) {
  const { error } = await _sb.from('site_audits').update(updates).eq('id', id);
  return !error;
}

async function loadHistory() {
  HIST_LOADING = true; renderPage();
  const { data } = await _sb.from('site_audits').select('*').eq('submitted_by', AUTH.uid).order('submitted_at', {ascending:false}).limit(100);
  MY_AUDITS = data || []; HIST_LOADING = false; renderPage();
}

async function checkApprover() {
  const { data } = await _sb.from('audit_approvers').select('grid_id').eq('email', AUTH.email);
  APPROVER_GRIDS = (data||[]).map(x=>x.grid_id).filter(Boolean);
  if (APPROVER_GRIDS.length > 0) loadPending();
  renderSidebar();
}

async function loadPending() {
  APP_LOADING = true; renderPage();
  const all = [];
  for (const g of APPROVER_GRIDS) {
    const { data } = await _sb.from('site_audits').select('*').eq('status','pending_approval').eq('grid_id',g).order('submitted_at',{ascending:false});
    if (data) all.push(...data);
  }
  if (APPROVER_GRIDS.length === 0) {
    const { data } = await _sb.from('site_audits').select('*').eq('status','pending_approval').order('submitted_at',{ascending:false});
    if (data) all.push(...data);
  }
  PEND_AUDITS = all; PENDING_BADGE = all.length; APP_LOADING = false;
  renderPage(); renderSidebar();
}

